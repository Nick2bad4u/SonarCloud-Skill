{
  "name": "sonar-manage-findings-skill",
  "version": "1.0.0",
  "private": false,
  "description": "Codex skill for inspecting and triaging SonarCloud and SonarQube findings.",
  "license": "Unlicense",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nick2bad4u/SonarCloud-Skill.git"
  },
  "bugs": {
    "url": "https://github.com/Nick2bad4u/SonarCloud-Skill/issues"
  },
  "homepage": "https://github.com/Nick2bad4u/SonarCloud-Skill#readme",
  "keywords": [
    "agent-skill",
    "agent-skills",
    "ai-agent",
    "claude-code",
    "codex",
    "cursor",
    "gemini-cli",
    "github-copilot",
    "openai",
    "opencode",
    "sonarcloud",
    "sonarqube",
    "static-analysis",
    "universal",
    "zed"
  ],
  "files": [
    "skills/sonar-manage-findings/SKILL.md",
    "skills/sonar-manage-findings/LICENSE.txt",
    "skills/sonar-manage-findings/agents/",
    "skills/sonar-manage-findings/assets/",
    "skills/sonar-manage-findings/references/",
    "skills/sonar-manage-findings/scripts/*.py",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=22.14"
  },
  "scripts": {
    "test": "npm run test:python",
    "validate": "node tools/validate-skill-package.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "publish:local": "npm run release:verify && npm publish --access public",
    "release:verify": "npm run validate && npm run test && npm run pack:dry-run",
    "update-actions": "npx actions-up --yes --style sha",
    "ruff:check:unsafe": "ruff check --unsafe-fixes scripts tests",
    "ruff:fix:unsafe": "ruff check --fix --unsafe-fixes scripts tests",
    "check:python": "npm run lint:python && npm run typecheck:python && npm run test:python && npm run compile:python",
    "check:python:unsafe": "npm run lint:python:unsafe && npm run typecheck:python && npm run test:python && npm run compile:python",
    "compile:python": "python -m compileall -q -x \"[\\\\/]\\.\" skills/sonar-manage-findings/scripts tests",
    "format:python": "npm run ruff:format && npm run ruff:fix",
    "lint:python": "npm run ruff:check && npm run ruff:format:check",
    "lint:python:unsafe": "npm run ruff:check:unsafe && npm run ruff:fix:unsafe",
    "pyright": "pyright",
    "python:bootstrap": "python -m pip install -r requirements-dev.txt",
    "python:venv": "python -m venv .venv && .venv\\Scripts\\activate && python -m pip install --upgrade pip && python -m pip install -r requirements-dev.txt",
    "python:venv:activate": ". .\\.venv\\Scripts\\Activate.ps1",
    "python:venv:deactivate": ". .\\.venv\\Scripts\\Deactivate.ps1",
    "ruff:check": "ruff check skills/sonar-manage-findings/scripts tests",
    "ruff:fix": "ruff check --fix skills/sonar-manage-findings/scripts tests",
    "ruff:format": "ruff format skills/sonar-manage-findings/scripts tests",
    "ruff:format:check": "ruff format --check skills/sonar-manage-findings/scripts tests",
    "test:python": "pytest",
    "typecheck:python": "mypy && pyright",
    "skillcheck": "skillcheck skills/sonar-manage-findings/SKILL.md --history --fail-on-regression",
    "lint:jscpd": "jscpd --config node_modules/jscpd-config-nick2bad4u/jscpd.json",
    "changelog:generate": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/SonarCloud-Skill --output CHANGELOG.md",
    "changelog:preview": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/SonarCloud-Skill --unreleased",
    "changelog:release-notes": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/SonarCloud-Skill --current",
    "lint:lychee": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml .",
    "lint:lychee:smoke": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml --dump-inputs README.md"
  },
  "codexSkill": {
    "name": "sonar-manage-findings",
    "path": "skills/sonar-manage-findings",
    "githubReleaseAssetPrefix": "sonarcloud-skill"
  },
  "devDependencies": {
    "git-cliff": "^2.13.1",
    "gitcliff-config-nick2bad4u": "^1.1.0",
    "jscpd": "^5.0.12",
    "jscpd-config-nick2bad4u": "^1.0.0",
    "lychee-config-nick2bad4u": "^1.0.0"
  }
}
